{
  "css.validate": false,
  "editor.formatOnSave": true,
  "editor.tabSize": 2,
  "headwind.runOnSave": false,
  "editor.codeActionsOnSave": {
    "source.fixAll": true
  },
  "eslint.options": {
    "extensions": [".js", ".jsx", ".md", ".mdx", ".ts", ".tsx"]
  },
  "eslint.validate": ["markdown", "javascript", "javascriptreact", "typescript", "typescriptreact"]
}
